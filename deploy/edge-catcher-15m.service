[Unit]
Description=Edge Catcher 15m Paper Trader (Strategy D)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=private-infra
WorkingDirectory=/home/private-infra/edge-catcher
EnvironmentFile=/home/private-infra/.private-infra/.env
ExecStart=/usr/bin/python3 -m edge_catcher paper-trade-15m --db data/paper_trades_15m.db
Restart=always
RestartSec=30
Nice=10

[Install]
WantedBy=multi-user.target
